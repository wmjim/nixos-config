// ~/.config/niri/config.kdl — niri 主配置文件

// 核心配置：输入设备、自启程序、显示器
include "core/input.kdl"
include "core/startup.kdl"
include "core/outputs.kdl"

// 视觉效果：动画、模糊、磨砂玻璃、布局、光标、概览
include "visual/animations.kdl"
include "visual/blur.kdl"
include "visual/frosted-glass.kdl"
include "visual/layout.kdl"
include "visual/cursor.kdl"
include "visual/overview.kdl"

// 快捷键：系统、导航、应用
include "binds/system.kdl"
include "binds/navigation.kdl"
include "binds/apps.kdl"

// 窗口规则
include "windowrules.kdl"

// 隐藏客户端装饰
// 注释：允许客户端自绘标题栏以统一窗口装饰风格
// prefer-no-csd

// 截图保存位置
screenshot-path "~/files/pictures/screenshots/niri/%Y-%m-%d_%H-%M-%S.png"

// xwayland-satellite 集成
xwayland-satellite {
   on
   path "xwayland-satellite"
}
