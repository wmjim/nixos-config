// 窗口规则
// 全局：默认平铺，圆角修饰
window-rule {
    geometry-corner-radius 3
    clip-to-geometry true
    draw-border-with-background false
    open-maximized false
    open-floating false            // 默认平铺
}

// 允许 Noctalia 执行通知操作和激活窗口
debug {
    honor-xdg-activation-with-invalid-serial
}

// ═══════════════════════════════════════════════
// 最大化窗口
// ═══════════════════════════════════════════════

// VS Code — 主窗口（最大化）
window-rule {
    match app-id="(?i)^code"
    open-maximized true
}

// Logisim Evolution — 逻辑电路模拟
window-rule {
    match app-id="com-cburch-logisim-Main"
    open-maximized true
}

// brave — 浏览器
window-rule {
    match app-id="brave"
    open-maximized true
}

// Zotero — 文献管理
window-rule {
    match app-id="(?i)zotero"
    open-maximized true
}


// ═══════════════════════════════════════════════
// 浮动窗口（按应用性质设定合适比例）
// ═══════════════════════════════════════════════

// cc-switch — 小型切换工具
window-rule {
    match app-id="(?i)cc-switch"
    open-floating true
    default-column-width { proportion 0.2; }
    default-window-height { proportion 0.25; }
}

// Fcitx5 配置 — 输入法设置
window-rule {
    match app-id="(?i)fcitx5"
    open-floating true
    default-column-width { proportion 0.5; }
    default-window-height { proportion 0.55; }
}

// PicGo — 图床上传工具
window-rule {
    match app-id="(?i)picgo"
    open-floating true
    default-column-width { proportion 0.35; }
    default-window-height { proportion 0.5; }
}

// btop++ — 终端系统监控
window-rule {
    match app-id="(?i)btop"
    open-floating true
    default-column-width { proportion 0.7; }
    default-window-height { proportion 0.7; }
}

// qView — 图片查看器
window-rule {
    match app-id="(?i)qview"
    open-floating true
    default-column-width { proportion 0.6; }
    default-window-height { proportion 0.7; }
}

// LocalSend — 局域网文件传输
window-rule {
    match app-id="(?i)localsend"
    open-floating true
    default-column-width { proportion 0.5; }
    default-window-height { proportion 0.6; }
}

// WeChat — 微信
window-rule {
    match app-id="(?i)wechat"
    open-floating true
    default-column-width { proportion 0.45; }
    default-window-height { proportion 0.7; }
}

// QQ
window-rule {
    match app-id="(?i)^qq$"
    open-floating true
    default-column-width { proportion 0.45; }
    default-window-height { proportion 0.7; }
}

// Telegram
window-rule {
    match app-id="(?i)telegram"
    open-floating true
    default-column-width { proportion 0.45; }
    default-window-height { proportion 0.7; }
}

// Discord
window-rule {
    match app-id="(?i)discord"
    open-floating true
    default-column-width { proportion 0.5; }
    default-window-height { proportion 0.7; }
}

// 欧陆词典 — 查词小窗
window-rule {
    match app-id="(?i)eudic"
    open-floating true
    default-column-width { proportion 0.3; }
    default-window-height { proportion 0.4; }
}

// gnome-text-editor
window-rule {
    match app-id="(?i)gnome-text-editor"
    open-floating true
    default-column-width { proportion 0.2; }
    default-window-height { proportion 0.1; }
}

// ═══════════════════════════════════════════════
// 侧边浮动
// ═══════════════════════════════════════════════

// Pot — 划词翻译（右侧浮动长条，满高度）
window-rule {
    match app-id="(?i)pot"
    default-column-width { proportion 0.2; }
    default-window-height { proportion 1.0; }
    default-floating-position x=0 y=0 relative-to="top-right"
}

// Pot — 偏好设置面板（覆盖上面的通用规则）
window-rule {
    match app-id="(?i)pot" title="Config"
    default-column-width { proportion 0.55; }
    default-window-height { proportion 0.70; }
}
