// 应用启动器、媒体控制与应用快捷键
binds {
    // Noctalia 启动器
    Mod+Space   hotkey-overlay-title="应用启动器"   { spawn-sh "noctalia msg panel-toggle launcher"; }

    // 音频控制
    XF86AudioRaiseVolume    allow-when-locked=true hotkey-overlay-title="音量+"        { spawn-sh "noctalia msg volume-up"; }
    XF86AudioLowerVolume    allow-when-locked=true hotkey-overlay-title="音量-"        { spawn-sh "noctalia msg volume-down"; }
    XF86AudioMute           allow-when-locked=true hotkey-overlay-title="麦克风开启"   { spawn-sh "noctalia msg volume-mute"; }
    XF86AudioMicMute        allow-when-locked=true hotkey-overlay-title="麦克风静音"   { spawn-sh "noctalia msg volume-micmute"; }

    // 亮度控制
    XF86MonBrightnessUp     allow-when-locked=true hotkey-overlay-title="亮度+"     { spawn-sh "noctalia msg brightness-up"; }
    XF86MonBrightnessDown   allow-when-locked=true hotkey-overlay-title="亮度-"     { spawn-sh "noctalia msg brightness-down"; }

    // 应用快捷方式
    Mod+T       hotkey-overlay-title="终端"         { spawn "ghostty"; }
    Mod+B       hotkey-overlay-title="浏览器"       { spawn "zen-beta"; }
    Mod+C       hotkey-overlay-title="VSCode"       { spawn "code"; }
    Mod+E       hotkey-overlay-title="文件管理器"   { spawn "nautilus"; }
    Mod+Shift+M hotkey-overlay-title="系统监控"     { spawn "ghostty" "-e" "btop"; }


    // Pot 划词翻译（Wayland 下只能用 curl 调用 API）
    Alt+T       hotkey-overlay-title="划词翻译"     { spawn-sh "curl -s '127.0.0.1:60828/selection_translate'"; }
    Alt+I       hotkey-overlay-title="输入翻译"     { spawn-sh "curl -s '127.0.0.1:60828/input_translate'"; }
    Alt+X       hotkey-overlay-title="截屏翻译"     { spawn-sh "grim -g \"$(slurp)\" /tmp/pot_ocr.png && tesseract /tmp/pot_ocr.png stdout -l eng+chi_sim 2>/dev/null | wl-copy --primary && curl -s '127.0.0.1:60828/selection_translate'"; }

    // PicGo 剪贴板图片上传（Wayland 下 Electron globalShortcut 不可用，通过 Server API 实现）
    Mod+Alt+P hotkey-overlay-title="上传剪贴板图片" { spawn-sh "picgo-clipboard-upload"; }
}
