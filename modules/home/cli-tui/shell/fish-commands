# NixOS 重建
sudo nixos-rebuild switch --flake ~/nixos-config#wsl     | 更新 WSL 系统
sudo nixos-rebuild switch --flake ~/nixos-config#laptop  | 更新 laptop 系统

# niri 相关
niri validate                                            | 解析 niri 配置文件并查看错误信息

# dms 相关
dms keybinds list                                        | 列出所有可用的快捷键提供者
dms keybinds show niri                                   | 以JSON格式显示指定提供者的快捷键
dms ipc call keybinds toggle niri                        | 通过IPC在DMS中直接显示按键绑定

# tmux 相关
tmux list-keys                                           | 查看tmux所有快捷键
tmux new -s <name>                                       | 新建命名会话
tmux ls                                                  | 列出所有会话
tmux attach -t <name>                                    | 附加到指定会话
tmux kill-session -t <name>                              | 关闭指定会话

# Git
git config --list                                        | 列出git当前所有配置
git reset --hard <commit_id>                             | 强制git仓库回退到某个历史提交
git revert <commit_id>                                   | 生成一个反向提交，抵消某次历史提交


# 系统
sensors                                                  | 查看CPU温度/风扇转速 