// ============================================================
// 磨砂玻璃桌面 — 统一窗口规则（niri v26.04）
// ============================================================
//
// Noctalia Shell 的界面元素（启动器、控制中心、overview）使用 layer-shell，
// window-rule 对 layer-shell 无效，必须用 layer-rule 启用模糊。
// xray：让窗口背景透过下面的其它窗口层


// 全局：所有窗口启用模糊
window-rule {
    background-effect {
        blur true
        xray false
    }
}

// --- 终端模拟器：磨砂玻璃的黄金场景 ---
window-rule {
    match app-id="com.mitchellh.ghostty"
    opacity 0.70
    background-effect {
        blur true
        xray true
    }
}

// 模糊概览壁纸
layer-rule {
    match namespace="^noctalia-backdrop"
    place-within-backdrop true
}

/*
  Noctalia（夜境）
  为所有界面图层禁用透视效果，让视觉效果更贴合真实观感。
  当系统支持 ext-background-effects 协议时，Noctalia 会自动推送模糊区域数据。
*/
layer-rule {
  match namespace="^noctalia-(bar-[^\"]+|notification|dock|panel|attached-panel|osd)$"
  background-effect {
    xray false
    // blur false
  }
}
