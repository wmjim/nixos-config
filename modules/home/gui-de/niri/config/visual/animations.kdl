// 动画
// https://niri-wm.github.io/niri/Configuration%3A-Animations.html
animations {
    // 关闭所有动画
    // off

    // 切换工作区动画
    workspace-switch {
        spring damping-ratio=1.0 stiffness=1000 epsilon=0.0001
    }

    // 窗口打开动画 — 雨滴水波纹效果
    window-open {
        duration-ms 500
        curve "ease-out-cubic"

        custom-shader r"
            vec4 open_color(vec3 coords_geo, vec3 size_geo) {
                float p = niri_clamped_progress;
                float envelope = p * (1.0 - p) * 4.0;
                float phase = p * 42.0;

                // Water surface ripples using overlapping directional waves
                // Creates a rain-on-water texture without converging to center
                float rx = 0.0;
                rx += sin(coords_geo.x * 45.0 + coords_geo.y * 20.0 - phase);
                rx += sin(coords_geo.x * 30.0 - coords_geo.y * 50.0 - phase * 1.15);
                rx += cos(coords_geo.x * 55.0 + coords_geo.y * 40.0 - phase * 0.85);
                rx += cos(coords_geo.x * 20.0 - coords_geo.y * 60.0 - phase * 1.3);
                rx += sin(coords_geo.x * 65.0 - coords_geo.y * 25.0 - phase * 1.05);
                rx += sin(coords_geo.x * 12.0 + coords_geo.y * 70.0 - phase * 0.75);
                rx *= 0.16;

                float ry = 0.0;
                ry += cos(coords_geo.x * 40.0 + coords_geo.y * 35.0 - phase * 1.05);
                ry += sin(coords_geo.x * 25.0 - coords_geo.y * 55.0 - phase * 0.9);
                ry += sin(coords_geo.x * 50.0 + coords_geo.y * 45.0 - phase * 1.15);
                ry += cos(coords_geo.x * 35.0 - coords_geo.y * 30.0 - phase * 1.2);
                ry += sin(coords_geo.x * 60.0 + coords_geo.y * 15.0 - phase * 0.95);
                ry += cos(coords_geo.x * 15.0 - coords_geo.y * 65.0 - phase * 1.25);
                ry *= 0.16;

                vec2 displaced = coords_geo.xy + vec2(rx, ry) * envelope * 0.03;

                vec3 coords_tex = niri_geo_to_tex * vec3(displaced, 1.0);
                vec4 color = texture2D(niri_tex, coords_tex.st);

                if (coords_geo.x < 0.0 || coords_geo.x > 1.0
                    || coords_geo.y < 0.0 || coords_geo.y > 1.0) {
                    return vec4(0.0);
                }

                return color * p;
            }
        "
    }

    // 关闭窗口动画 — 水波纹消散效果
    window-close {
        duration-ms 500
        curve "ease-out-cubic"

        custom-shader r"
            vec4 close_color(vec3 coords_geo, vec3 size_geo) {
                float p = niri_clamped_progress;

                vec2 center = vec2(0.5, 0.5);
                vec2 delta = coords_geo.xy - center;
                float dist = length(delta);
                vec2 dir = dist > 0.001 ? delta / dist : vec2(0.0, 0.0);

                // Multi-frequency water ripples radiating from center
                float w1 = sin(dist * 14.0 - p * 24.0) * exp(-dist * 3.0);
                float w2 = cos(dist * 26.0 - p * 42.0) * exp(-dist * 5.0) * 0.45;
                float ripple = w1 + w2;

                // Distortion grows as window closes
                float envelope = p * exp(-dist * 2.5);
                float displacement = ripple * envelope * 0.12;

                // Drain toward center (like sinking into water)
                float drain = p * p * p * 0.35;

                // Slight tangential wobble
                float tangent = sin(dist * 20.0 - p * 34.0) * envelope * 0.025;
                vec2 perp = vec2(-dir.y, dir.x);

                vec2 displaced = coords_geo.xy
                    + dir * displacement
                    - dir * drain
                    + perp * tangent;

                vec3 coords_tex = niri_geo_to_tex * vec3(displaced, 1.0);
                vec4 color = texture2D(niri_tex, coords_tex.st);

                if (coords_geo.x < 0.0 || coords_geo.x > 1.0
                    || coords_geo.y < 0.0 || coords_geo.y > 1.0) {
                    return vec4(0.0);
                }

                // Fade out with slight delay so ripple is visible
                float fade = 1.0 - p * p;
                return color * fade;
            }
        "
    }

    horizontal-view-movement {
        spring damping-ratio=1.0 stiffness=800 epsilon=0.0001
    }

    // 窗口移动动画
    window-movement {
        spring damping-ratio=1.0 stiffness=800 epsilon=0.0001
    }

    // 窗口大小调整动画
    window-resize {
        spring damping-ratio=0.7 stiffness=800 epsilon=0.0001

        custom-shader r"
            vec4 resize_color(vec3 coords_curr_geo, vec3 size_curr_geo) {
                vec3 coords_tex_next = niri_geo_to_tex_next * coords_curr_geo;
                vec4 color = texture2D(niri_tex_next, coords_tex_next.st);
                return color;
            }
        "
    }

    // 通知的打开/关闭动画
    config-notification-open-close {
        spring damping-ratio=0.6 stiffness=1000 epsilon=0.001
    }

    // 对话框的打开/关闭动画
    exit-confirmation-open-close {
        spring damping-ratio=0.6 stiffness=500 epsilon=0.01
    }

    // 截图界面的打开（淡入）动画
    screenshot-ui-open {
        duration-ms 200
        curve "ease-out-quad"
    }

    // 概览的打开/关闭缩放动画
    overview-open-close {
        spring damping-ratio=1.0 stiffness=800 epsilon=0.0001
    }

    // 最近窗口切换器的关闭淡出动画
    recent-windows-close {
        spring damping-ratio=1.0 stiffness=800 epsilon=0.001
    }
}
