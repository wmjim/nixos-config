// 窗口规则
// 全局：默认所有窗口以浮动窗口打开
window-rule {
    geometry-corner-radius 3      // 圆角
    clip-to-geometry true         // 将窗口内容剪辑到圆角边界
    draw-border-with-background false
    open-maximized false          // 默认不最大化
    open-floating true            // 默认浮动
    default-column-width { proportion 0.65; }
    default-window-height { proportion 0.75; }
}

// 允许 Noctalia 执行通知操作和激活窗口
debug {
    honor-xdg-activation-with-invalid-serial
}

// ═══════════════════════════════════════════════
// 以下应用以最大化方式打开
// ═══════════════════════════════════════════════

// VS Code — 代码编辑器
window-rule {
    match app-id="(?i)^code"
    open-maximized true
    open-floating false
}

// Logisim Evolution — 逻辑电路模拟
window-rule {
    match app-id="logisim-evolution"
    open-maximized true
    open-floating false
}

// Microsoft Edge — 浏览器
window-rule {
    match app-id="microsoft-edge"
    open-maximized true
    open-floating false
}

// Zotero — 文献管理
window-rule {
    match app-id="(?i)zotero"
    open-maximized true
    open-floating false
}

// Folo — RSS 阅读器
window-rule {
    match app-id="folo"
    open-maximized true
    open-floating false
}

// ═══════════════════════════════════════════════
// 特殊定位 / 尺寸覆盖
// ═══════════════════════════════════════════════

// Pot — 划词翻译（右侧浮动长条，满高度）
window-rule {
    match app-id="(?i)pot"
    default-column-width { proportion 0.2; }
    default-window-height { proportion 1.0; }
    default-floating-position x=0 y=0 relative-to="top-right"
}

// Pot — 偏好设置面板（覆盖上面的通用规则）
window-rule {
    match app-id="(?i)pot" title="Config"
    default-column-width { proportion 0.55; }
    default-window-height { proportion 0.70; }
}
