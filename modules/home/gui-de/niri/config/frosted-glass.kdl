// ============================================================
// 磨砂玻璃桌面 — 统一窗口规则（niri v26.04）
// ============================================================
//
// Noctalia Shell 的界面元素（启动器、控制中心、overview）使用 layer-shell，
// window-rule 对 layer-shell 无效，必须用 layer-rule 启用模糊。

// --- Noctalia Shell 覆盖层磨砂 ---
// 将模糊壁纸放置在概览中
// layer-rule {
//     match namespace="dms:blurwallpaper"
//     place-within-backdrop true
// }
// 将 Noctalia 的专用背景层置于 Niri 概览背景之中
layer-rule {
  match namespace="^noctalia-backdrop"
  place-within-backdrop true
}
// 设计：opacity（透明度）+ background-effect blur（背景模糊）+ xray false（非穿透模糊）
//
// 透明度层级一览（压低透明度才能看清模糊后的背景）：
//   0.70–0.75   终端模拟器 — 最透，磨砂核心
//   0.78–0.82   代码编辑器、文件管理器
//   0.85        浏览器
//   0.90        设置面板、浮动对话框
//   1.00        视频/图片/游戏 — 不透明，无模糊
//
// 需要调整 GPU 负载时，改 blur.kdl 里的 passes 参数即可。
// ============================================================

// 全部模糊处理，不显示透视效果，使其看起来更真实。
window-rule {
  background-effect {
    blur true
    xray false
  }
}

// 在所有表面上禁用X光效果，使其看起来更真实。
// 此处无需将模糊设置为“true”，它是自动的
layer-rule {
  match namespace="^noctalia-(bar-[^\"]+|notification|dock|panel)$"
  background-effect {
    xray false
    //blur false
  }
}




